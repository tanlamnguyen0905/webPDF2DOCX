# ===== Shared (docker-compose) =====
COMPOSE_PROJECT_NAME=pdf2word

# ===== MySQL =====
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=pdf_converter
MYSQL_USER=pdf_user
MYSQL_PASSWORD=pdf_password
MYSQL_PORT=3306

# ===== Backend (Spring Boot) =====
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=local
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ACCESS_EXPIRATION_SECONDS=3600
JWT_REFRESH_EXPIRATION_SECONDS=604800
WORKER_SHARED_SECRET=change-me-worker-secret

# ===== LocalStack (S3 + SQS) =====
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localstack:4566
S3_BUCKET=pdf-converter
SQS_QUEUE_NAME=pdf-conversion-jobs
SQS_DLQ_NAME=pdf-conversion-jobs-dlq

# ===== Frontend (Next.js) =====
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1