# Dùng khi chạy backend trực tiếp (không qua docker-compose).
SPRING_PROFILES_ACTIVE=local
BACKEND_PORT=8080

SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/pdf_converter?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=pdf_user
SPRING_DATASOURCE_PASSWORD=pdf_password

JWT_SECRET=change-me-to-a-long-random-secret
JWT_ACCESS_EXPIRATION_SECONDS=3600
JWT_REFRESH_EXPIRATION_SECONDS=604800
WORKER_SHARED_SECRET=change-me-worker-secret

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566
S3_BUCKET=pdf-converter
SQS_QUEUE_NAME=pdf-conversion-jobs
